{
  "manifest_version": 3,
  "name": "Auto Job Applicator",
  "version": "1.0.0",
  "description": "Automate job scraping, ranking, resume optimization, and application tracking.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "alarms",
    "background",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.workday.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://jobs.ashbyhq.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle",
      "css": ["content/linkedin.css"]
    },
    {
      "matches": ["https://*.greenhouse.io/*", "https://jobs.lever.co/*", "https://*.myworkdayjobs.com/*", "https://jobs.ashbyhq.com/*"],
      "js": ["content/career-page.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/form-scraper.js", "content/status-detector.js", "content/login-detector.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://www.linkedin.com/jobs/*",
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://jobs.ashbyhq.com/*"
      ]
    }
  ],
  "web_accessible_resources": [{
    "resources": ["assets/*"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
